{
  "name": "@afauth/server",
  "version": "0.0.1",
  "description": "AFAuth server SDK — middleware, account state, claim flow",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run --passWithNoTests",
    "lint": "echo TODO: configure lint",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AFAuthHQ/typescript-sdk.git",
    "directory": "packages/server"
  },
  "publishConfig": {
    "access": "public"
  }
}
