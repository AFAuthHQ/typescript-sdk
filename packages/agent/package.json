{
  "name": "@afauthhq/agent",
  "version": "0.0.1",
  "description": "AFAuth agent SDK — keypair, did:key, signed requests, protocol-aware builders",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run --passWithNoTests",
    "coverage": "vitest run --coverage --passWithNoTests",
    "lint": "echo TODO: configure lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@afauthhq/core": "workspace:*",
    "@noble/curves": "^2.2.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AFAuthHQ/typescript-sdk.git",
    "directory": "packages/agent"
  },
  "publishConfig": {
    "access": "public"
  }
}
